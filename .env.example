# Shopify App
SHOPIFY_API_KEY=""
SHOPIFY_API_SECRET=""
SHOPIFY_APP_URL="https://tu-dominio.com"
SCOPES="write_products,read_products,write_inventory"

# SIESA - Headers de autenticación
CLIENT_ID=""
CONNIKEY=""
CONNITOKEN=""

# SIESA - Parámetros de consulta
URLSIESAINV=""
IDCOMPANIA=""
DESCRIPCION=""
PAGINACION="numPag=1|tamPag=100"
PARAMETROS=""

# Shopify - ID de la ubicación (bodega)
IDLOCATION=""

# Cron - Expresión para sincronización automática (default: cada 3 horas)
SYNC_CRON="0 */3 * * *"

# Entorno
NODE_ENV="production"
